# Provider LLM: deepseek (default) | mistral | local
AI_PROVIDER=deepseek

# DeepSeek (https://platform.deepseek.com) — la tua chiave
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# opzionale
LLM_TEMPERATURE=0.3

# Ricerca web (punto di partenza, accessi, condizioni): Tavily. Senza key il tool
# risponde "non configurato". Key: https://tavily.com  (piano free ~1000/mese)
TAVILY_API_KEY=

# --- alternative provider (se AI_PROVIDER cambia) ---
# MISTRAL_API_KEY=
# MISTRAL_MODEL=mistral-small-latest
# LOCAL_BASE_URL=http://127.0.0.1:11434/v1
# LOCAL_MODEL=qwen2.5
